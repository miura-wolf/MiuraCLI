{
  "name": "miuraswarm",
  "version": "0.1.0",
  "description": "Autonomous AI agent orchestrator — CLI-first, plugin-based, event-driven, local-first with llama.cpp",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "miura": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc && bun build src/cli/index.ts --compile --outfile dist/miura.exe",
    "postinstall": "bun install --no-dev",
    "dev": "tsc --watch",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "lint": "oxlint",
    "start": "bun run src/cli/index.ts",
    "typecheck": "tsc --noEmit",
    "compile": "bun build src/cli/index.ts --compile --outfile dist/miura.exe",
    "clean": "rm -rf dist/"
  },
  "keywords": [
    "ai",
    "agents",
    "orchestrator",
    "multi-agent",
    "cli",
    "plugin",
    "event-driven",
    "llm",
    "local-inference"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "bun": ">=1.3.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "oxlint": "^0.16.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "chokidar": "^5.0.0",
    "commander": "^14.0.3",
    "fast-glob": "^3.3.3",
    "tree-sitter-go": "^0.25.0",
    "tree-sitter-javascript": "^0.25.0",
    "tree-sitter-python": "^0.25.0",
    "tree-sitter-typescript": "^0.23.2",
    "web-tree-sitter": "^0.26.9"
  }
}
