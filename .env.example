# ── MiuraCLI Environment Variables ──────────────────────────────────────
# Copy this file to .env and fill in the keys you want to use.
# The system auto-detects which providers are available at startup.

# ── Local Inference (llama-server) ──────────────────────────────────────
# Use local GGUF models via llama.cpp. No API key needed.
MIURA_LLAMA_SERVER_PATH=C:/llama/bin/llama-server.exe
MIURA_LLAMA_MODEL_PATH=C:/models/qwen2.5-coder-7b-q4_k_m.gguf
MIURA_LLAMA_PORT=8050
MIURA_LLAMA_GPU_LAYERS=99
MIURA_LLAMA_CONTEXT=8192

# ── Free / Cheap ─────────────────────────────────────────────────────────
# GROQ_API_KEY=gsk_...                          # Groq LPU Inference
# NVIDIA_NIM_API_KEY=nvapi-...                  # NVIDIA NIM (NV API Catalog)

# ── Paid APIs ────────────────────────────────────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-...                   # Claude Opus/Sonnet/Haiku
# OPENROUTER_API_KEY=sk-or-...                   # OpenRouter (multi-model)
# GOOGLE_AI_API_KEY=...                           # Gemini
# CEREBRAS_API_KEY=...                            # Cerebras CS-3
# COHERE_API_KEY=...                              # Cohere
# MISTRAL_API_KEY=...                             # Mistral AI
# SAMBANOVA_API_KEY=...                           # SambaNova
# ZYPHRA_API_KEY=...                              # Zyphra

# ── Model Router ────────────────────────────────────────────────────────
# Default routing: groq (llama-3.3-70b) → ollama (qwen2.5-coder-7b)
# If you set NVIDIA_NIM_API_KEY, the system detects it and
# model-router will eventually re-prioritize NIM models.
# Override per role with /model command in REPL.
